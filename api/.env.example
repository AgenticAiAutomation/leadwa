# Leadwa API Environment Variables
# Copy to .env and fill in real values

# Database
DATABASE_URL=postgresql://leadwa_user:PASSWORD@localhost/leadwa

# Security
JWT_SECRET=<generate with: openssl rand -hex 32>
CLICK_BEACON_SECRET=<generate with: openssl rand -hex 32>

# Cloudflare (for KV sync from API)
CF_ACCOUNT_ID=<your Cloudflare account ID>
CF_KV_NAMESPACE_ID=<KV namespace ID from: wrangler kv:namespace list>
CF_API_TOKEN=<API token with Workers KV Storage:Edit permission>
